				{
					"name": "Get Jobs (Paginated & Filtered)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "query GetJobs($query: String, $status: String, $page: Int, $pageSize: Int) {\n  jobs(query: $query, status: $status, page: $page, pageSize: $pageSize) {\n    jobs {\n      id\n      jobTitle\n      department\n      level\n      location\n      marketMedian\n      internalMedian\n      compaRatio\n      status\n    }\n    totalCount\n    totalPages\n  }\n}",
								"variables": "{\n  \"query\": \"\",\n  \"status\": \"active\",\n  \"page\": 1,\n  \"pageSize\": 10\n}"
							}
						},
						"url": {
							"raw": "http://localhost:4000/api/graphql",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "4000",
							"path": [
								"api",
								"graphql"
							]
						}
					},
					"response": []
				},
				{

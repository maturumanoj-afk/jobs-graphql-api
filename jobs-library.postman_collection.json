							"graphql": {
								"query": "query GetJob($id: ID!) {\n  job(id: $id) {\n    id\n    jobTitle\n    department\n    level\n    location\n    status\n    createdAt\n  }\n}",
								"variables": "{\n  \"id\": \"PASTE_JOB_ID_HERE\"\n}"

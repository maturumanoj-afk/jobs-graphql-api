							"graphql": {
								"query": "mutation CreateJob($input: JobInput!) {\n  createJob(input: $input) {\n    id\n    jobTitle\n    department\n    status\n  }\n}",
								"variables": "{\n  \"input\": {\n    \"jobTitle\": \"New API Tester\",\n    \"department\": \"Engineering\",\n    \"level\": \"Senior\",\n    \"location\": \"Remote\",\n    \"marketMedian\": 150000,\n    \"internalMedian\": 155000,\n    \"status\": \"active\",\n    \"employmentType\": \"full_time\",\n    \"remoteEligible\": true,\n    \"headcountBudget\": 2\n  }\n}"
